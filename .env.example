# ============================================
# Lampy — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
#
# 1. Create a Supabase project at https://supabase.com
# 2. Find URL + anon key in: Settings → API
# 3. Get an Anthropic API key at https://console.anthropic.com

# --- Supabase (required) ---
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbG...your-anon-key

# --- Anthropic (set as Supabase secret, NOT in the app) ---
# Do NOT put this in .env — it goes server-side only:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-api03-...
